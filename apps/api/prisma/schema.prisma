generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  GUEST
  HOST
  ADMIN
}

enum HostVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum BookingStatus {
  HOLD
  PAYMENT_PENDING
  CONFIRMED_DEPOSIT
  BALANCE_DUE
  CONFIRMED_PAID
  CANCELLED
  REFUNDED
  COMPLETED
}

enum PaymentPlan {
  FULL
  DEPOSIT_50
}

enum PaymentStatus {
  INITIATED
  CAPTURED
  FAILED
  REFUNDED
}

enum PayoutStatus {
  NOT_ELIGIBLE
  ELIGIBLE
  SCHEDULED
  PAID
  ON_HOLD
  REVERSED
}

enum IssueCategory {
  MAINTENANCE
  CLEANLINESS
  NOISE
  SAFETY
  OTHER
}

enum IssueUrgency {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum LedgerEventType {
  PAYMENT_CAPTURED
  REFUND_ISSUED
  PAYOUT_SCHEDULED
  PAYOUT_SENT
  BALANCE_CARRY_FORWARD
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique
  passwordHash   String?
  fullName       String
  role           UserRole
  isActive       Boolean     @default(true)
  refreshToken   String?
  auth0Sub       String?     @unique
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  hostProfile    Host?
  listings       Listing[]
  holds          Hold[]
  bookings       Booking[]
  phone          String?
  avatarUrl      String?
  auditLogs      AuditLog[]  @relation("AuditActor")
  wishlists      Wishlist[]
  reviews        Review[]
  guestNotifications GuestNotification[]
  guestPreference    GuestPreference?
  conversationsAsOne Conversation[]     @relation("ConversationsAsOne")
  conversationsAsTwo Conversation[]     @relation("ConversationsAsTwo")
  sentMessages       Message[]
  guestIssues        GuestIssue[]
  referralCode       String?     @unique
  referrals          Referral[]  @relation("ReferrerReferrals")
  referredBy         Referral?   @relation("ReferredUserReferral")
  creditLedger       CreditLedger[]
}

model Host {
  id                  String                 @id @default(cuid())
  userId              String                 @unique
  verificationStatus  HostVerificationStatus @default(PENDING)
  payoutAccountRef    String?
  payoutEnabled       Boolean                @default(false)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  user                User                   @relation(fields: [userId], references: [id])
  listings            Listing[]
  payoutLines         PayoutLine[]
  notifications       HostNotification[]
}

model Listing {
  id                  String               @id @default(cuid())
  hostId              String
  createdById         String
  title               String
  description         String
  city                String
  state               String
  country             String               @default("India")
  latitude            Float?
  longitude           Float?
  timezone            String               @default("Asia/Kolkata")
  status              ListingStatus        @default(PENDING_APPROVAL)
  preparationGuide    Json?
  propertyDirections  Json?
  propertyManual      Json?
  needsReapproval     Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  host                Host                 @relation(fields: [hostId], references: [id])
  createdBy           User                 @relation(fields: [createdById], references: [id])
  media               ListingMedia[]
  tags                ListingTag[]
  rateRules           RateRule[]
  seasonalRates       SeasonalRate[]
  availabilityBlocks  AvailabilityBlock[]
  holds               Hold[]
  bookings            Booking[]
  payoutLines         PayoutLine[]
  wishlists           Wishlist[]
  reviews             Review[]
  conversations       Conversation[]
  issues               GuestIssue[]

  @@index([hostId])
  @@index([status, createdAt])
}

model ListingMedia {
  id           String   @id @default(cuid())
  listingId    String
  url          String
  mediaType    String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Tag {
  id          String       @id @default(cuid())
  category    String
  name        String
  createdAt   DateTime     @default(now())
  listingTags ListingTag[]

  @@unique([category, name])
}

model ListingTag {
  listingId   String
  tagId       String
  listing     Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tag         Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([listingId, tagId])
}

model RateRule {
  id                String   @id @default(cuid())
  listingId         String
  baseNightlyRate   Int
  cleaningFee       Int      @default(0)
  minNights         Int      @default(1)
  maxGuests         Int      @default(2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  listing           Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model SeasonalRate {
  id              String   @id @default(cuid())
  listingId       String
  startsAt        DateTime
  endsAt          DateTime
  nightlyRate     Int
  createdAt       DateTime @default(now())
  listing         Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, startsAt, endsAt])
}

model AvailabilityBlock {
  id             String   @id @default(cuid())
  listingId      String
  startsAt       DateTime
  endsAt         DateTime
  reason         String
  createdAt      DateTime @default(now())
  listing        Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, startsAt, endsAt])
}

model Hold {
  id               String      @id @default(cuid())
  listingId        String
  guestId          String
  startsAt         DateTime
  endsAt           DateTime
  expiresAt        DateTime
  priceSnapshot    Json
  idempotencyKey   String      @unique
  createdAt        DateTime    @default(now())
  listing          Listing     @relation(fields: [listingId], references: [id])
  guest            User        @relation(fields: [guestId], references: [id])
  booking          Booking?

  @@index([listingId])
}

model Booking {
  id               String       @id @default(cuid())
  listingId        String
  guestId          String
  holdId           String       @unique
  status           BookingStatus @default(PAYMENT_PENDING)
  plan             PaymentPlan
  startsAt         DateTime
  endsAt           DateTime
  priceSnapshot    Json
  guestDetails     Json?
  checkInData      Json?
  checkOutData     Json?
  balanceDueAt     DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  listing          Listing      @relation(fields: [listingId], references: [id])
  guest            User         @relation(fields: [guestId], references: [id])
  hold             Hold         @relation(fields: [holdId], references: [id])
  payments         Payment[]
  refunds          Refund[]
  review           Review?
  conversations    Conversation[]
  issues           GuestIssue[]

  @@index([listingId, status])
  @@index([guestId, status])
  @@index([status, createdAt])
  @@index([listingId, startsAt, endsAt])
}

model Payment {
  id                 String        @id @default(cuid())
  bookingId          String
  amount             Int
  type               PaymentPlan
  status             PaymentStatus @default(INITIATED)
  gateway            String        @default("razorpay")
  gatewayPaymentRef  String?
  gatewayOrderRef    String?
  idempotencyKey     String        @unique
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  booking            Booking       @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([status, createdAt])
}

model Refund {
  id                 String        @id @default(cuid())
  bookingId          String
  paymentId          String?
  amount             Int
  reason             String
  gatewayRefundRef   String?
  createdAt          DateTime      @default(now())
  booking            Booking       @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model PayoutLine {
  id                 String       @id @default(cuid())
  hostId             String
  listingId          String
  bookingId          String
  amount             Int
  eligibleAt         DateTime
  status             PayoutStatus @default(NOT_ELIGIBLE)
  batchId            String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  host               Host         @relation(fields: [hostId], references: [id])
  listing            Listing      @relation(fields: [listingId], references: [id])
  batch              PayoutBatch? @relation(fields: [batchId], references: [id])

  @@index([hostId, status])
}

model PayoutBatch {
  id                 String       @id @default(cuid())
  runDate            DateTime
  status             PayoutStatus @default(SCHEDULED)
  totalAmount        Int          @default(0)
  createdAt          DateTime     @default(now())
  lines              PayoutLine[]
}

model LedgerEvent {
  id                 String          @id @default(cuid())
  bookingId          String?
  payoutLineId       String?
  type               LedgerEventType
  amount             Int
  currency           String          @default("INR")
  metadata           Json
  createdAt          DateTime        @default(now())

  @@index([bookingId])
}

model AuditLog {
  id                 String   @id @default(cuid())
  actorUserId        String?
  action             String
  resourceType       String
  resourceId         String
  metadata           Json
  createdAt          DateTime @default(now())
  actor              User?    @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([resourceType, resourceId])
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model AdminNotification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  metadata  Json     @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
}

model HostNotification {
  id        String   @id @default(cuid())
  hostId    String
  type      String
  title     String
  message   String
  metadata  Json     @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  host      Host     @relation(fields: [hostId], references: [id])

  @@index([hostId, isRead, createdAt])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])

  @@unique([userId, listingId])
  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  userId    String
  listingId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
  booking   Booking  @relation(fields: [bookingId], references: [id])

  @@index([listingId])
  @@index([userId])
}

model GuestNotification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  metadata  Json     @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt])
}

model Conversation {
  id          String    @id @default(cuid())
  type        String    // GUEST_HOST, HOST_ADMIN
  userOneId   String    // guest (GUEST_HOST) or host (HOST_ADMIN)
  userTwoId   String    // host (GUEST_HOST) or admin (HOST_ADMIN)
  listingId   String?
  bookingId   String?
  subject     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userOne     User      @relation("ConversationsAsOne", fields: [userOneId], references: [id])
  userTwo     User      @relation("ConversationsAsTwo", fields: [userTwoId], references: [id])
  listing     Listing?  @relation(fields: [listingId], references: [id])
  booking     Booking?  @relation(fields: [bookingId], references: [id])
  messages    Message[]

  @@unique([userOneId, userTwoId, listingId])
  @@index([userOneId])
  @@index([userTwoId])
  @@index([type])
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  senderId        String
  senderRole      UserRole
  body            String
  isRead          Boolean      @default(false)
  createdAt       DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversationId], references: [id])
  sender          User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}

model GuestPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  dietaryNeeds      String[]
  wellnessInterests String[]
  accessibility     String?
  roomPreference    String?
  experienceLevel   String?
  arrivalPreference String?
  emergencyContact  Json?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  key          String   @unique
  userId       String
  requestPath  String
  requestHash  String
  status       String   @default("PROCESSING")
  httpStatus   Int?
  responseBody Json?
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([expiresAt])
}

model GuestIssue {
  id          String        @id @default(cuid())
  bookingId   String
  listingId   String
  guestId     String
  category    IssueCategory
  description String
  urgency     IssueUrgency  @default(MEDIUM)
  photoUrl    String?
  status      IssueStatus   @default(OPEN)
  hostNotes   String?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  booking     Booking       @relation(fields: [bookingId], references: [id])
  listing     Listing       @relation(fields: [listingId], references: [id])
  guest       User          @relation(fields: [guestId], references: [id])

  @@index([bookingId])
  @@index([listingId, status])
  @@index([guestId])
  @@index([status, createdAt])
}

enum ReferralStatus {
  PENDING
  SIGNED_UP
  FIRST_BOOKING
  CREDITED
}

model Referral {
  id              String         @id @default(cuid())
  referrerId      String
  referredUserId  String?        @unique
  referralCode    String         @unique
  status          ReferralStatus @default(PENDING)
  referrerCredit  Int            @default(0)
  referredCredit  Int            @default(0)
  creditedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  referrer        User           @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referredUser    User?          @relation("ReferredUserReferral", fields: [referredUserId], references: [id])

  @@index([referrerId])
}

model CreditLedger {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  reason      String
  referenceId String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}