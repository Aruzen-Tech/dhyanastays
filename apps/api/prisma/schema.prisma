// ─── Pre-booking add-ons (Phase 2 §5.7) ───────────────────────────────────────

enum CancellationTier {
  FLEXIBLE        // full refund up to 24h before check-in
  MODERATE        // 50% refund 24-72h, 0% inside 24h
  STRICT          // 50% refund up to 7d, 0% inside 7d
  NON_REFUNDABLE  // no refund once confirmed
}

enum AddOnScope {
  GLOBAL    // applies to all listings
  CLUSTER   // applies within a cluster (future)
  LISTING   // applies to a single listing
}

enum AddOnStatus {
  PENDING   // awaiting admin approval
  APPROVED  // visible to guests
  REJECTED
  RETIRED   // no longer bookable (historical)
}

enum AddOnState {
  QUOTED
  HELD
  CONFIRMED
  DELIVERED
  CANCELLED
  REFUNDED
}

model ServiceProvider {
  id           String       @id @default(cuid())
  name         String
  kind         ServiceType
  ownerUserId  String
  contactEmail String?
  contactPhone String?
  payoutMethod Json?
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  owner        User         @relation("ProviderOwner", fields: [ownerUserId], references: [id])
  addOns       AddOn[]

  @@index([ownerUserId])
  @@index([kind, active])
}

model AddOn {
  id               String           @id @default(cuid())
  providerId       String
  title            String
  description      String
  priceMinor       Int              // paise — per unit
  commissionRate   Float            @default(0.15) // platform cut (0–1)
  currency         String           @default("INR")
  cancellationTier CancellationTier @default(MODERATE)
  minLeadHours     Int              @default(24)
  maxPerBooking    Int              @default(1)
  availability     Json?            // free-form rules (days of week, capacity, etc.)
  scope            AddOnScope       @default(GLOBAL)
  clusterId        String?
  listingId        String?
  status           AddOnStatus      @default(PENDING)
  reviewedBy       String?
  reviewNotes      String?
  reviewedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  provider         ServiceProvider  @relation(fields: [providerId], references: [id])
  listing          Listing?         @relation("ListingAddOns", fields: [listingId], references: [id])
  bookingAddOns    BookingAddOn[]

  @@index([providerId])
  @@index([status, scope])
  @@index([listingId])
}

model BookingAddOn {
  id            String     @id @default(cuid())
  bookingId     String
  addOnId       String
  providerId    String
  quantity      Int        @default(1)
  unitPrice     Int        // paise — snapshot
  totalPrice    Int        // paise — unitPrice * quantity, snapshot
  commission    Int        // paise — platform cut, snapshot
  providerShare Int        // paise — totalPrice - commission, snapshot
  state         AddOnState @default(QUOTED)
  snapshotHmac  String     // signed slice identifying this add-on in the price snapshot
  cancelledAt   DateTime?
  refundedAt    DateTime?
  refundAmount  Int?       // paise — actual refund given, if any
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  booking       Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addOn         AddOn      @relation(fields: [addOnId], references: [id])

  @@index([bookingId])
  @@index([addOnId, state])
  @@index([providerId, state])
}

// ─── Phase 2 §5.17 — Notification outbox + preferences ──────────────────────

enum OutboxStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  IN_APP
}

model NotificationPreference {
  userId     String   @id
  channels   Json     @default("{}")
  quietHours Json?
  updatedAt  DateTime @default(now()) @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationOutbox {
  id            String              @id @default(cuid())
  userId        String
  kind          String
  channel       NotificationChannel
  payload       Json
  status        OutboxStatus        @default(PENDING)
  attempts      Int                 @default(0)
  lastError     String?
  nextAttemptAt DateTime            @default(now())
  sentAt        DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([userId, createdAt(sort: Desc)])
  @@index([kind, createdAt(sort: Desc)])
}

// ── Phase 3 §5.12 SOS & support ────────────────────────────────────────────

enum SosTier {
  MEDICAL
  SECURITY
  TRANSPORT
  OTHER
}

enum SosStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  FALSE_ALARM
}

model TrustedContact {
  id        String   @id @default(cuid())
  userId    String
  name      String
  /** E.164 phone, optional. At least one of phone or email must be set (enforced server-side). */
  phone     String?
  /** Email, optional. At least one of phone or email must be set (enforced server-side). */
  email     String?
  relation  String
  primary   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SosIncident {
  id          String       @id @default(cuid())
  userId      String
  bookingId   String?
  tier        SosTier
  lat         Float
  lng         Float
  message     String?
  status      SosStatus    @default(OPEN)
  openedAt    DateTime     @default(now())
  ackedAt     DateTime?
  ackedBy     String?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  booking     Booking?     @relation(fields: [bookingId], references: [id])
  broadcasts  SosBroadcast[]
  messages    SosMessage[]

  @@index([userId])
  @@index([status, openedAt(sort: Desc)])
  @@index([bookingId])
}

/**
 * Per-incident chat thread between the guest and the responding admin.
 * Polling-based real-time (3s on guest, 5s on admin) keeps the surface
 * simple; SSE/WebSocket upgrade is a Phase 2 optimization.
 */
model SosMessage {
  id          String      @id @default(cuid())
  incidentId  String
  senderId    String
  /** 'GUEST' | 'ADMIN' — derived from the requesting controller, not from JWT role. */
  senderRole  String
  content     String
  createdAt   DateTime    @default(now())

  incident    SosIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, createdAt])
}

model SosBroadcast {
  id         String      @id @default(cuid())
  incidentId String
  channel    String
  target     String
  status     String      @default("QUEUED")
  lastError  String?
  sentAt     DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  incident   SosIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
}

// ─── Phase 3 §5.14 Investor dashboard ─────────────────────────────────────────

enum DistributionStatus {
  CALCULATED
  PAID
  FAILED
}

enum CapitalCallStatus {
  OPEN
  FUNDED
  CLOSED
  CANCELLED
}

enum InvestorDocumentKind {
  AGREEMENT
