  startsAt    DateTime?
  endsAt      DateTime?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  owner       User              @relation("TripGroupOwner", fields: [ownerId], references: [id])
  members     TripGroupMember[]
