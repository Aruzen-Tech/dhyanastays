generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Legacy role enum (kept for JWT backward-compat and Message.senderRole) ───
enum UserRole {
  GUEST
  HOST
  ADMIN
}

// ─── Phase 1: expanded identity model ────────────────────────────────────────

enum UserKind {
  GUEST
  OWNER      // property operator (maps from HOST)
  INVESTOR   // capital provider
  STAFF      // internal team (maps from ADMIN)
}

enum AdminLevel {
  L1 // Super Admin
  L2 // Operational Admin
  L3 // Cluster / Regional Admin
  L4 // Property-Level Admin
  L5 // Service-Level Admin
}

enum ServiceType {
  TRANSPORT
  FOOD
  WELLNESS
  EXPERIENCE
  CONCIERGE
  HOUSEKEEPING
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MfaType {
  TOTP
  SMS
  EMAIL
}

enum HostVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum BookingStatus {
  HOLD
  PAYMENT_PENDING
  CONFIRMED_DEPOSIT
  BALANCE_DUE
  CONFIRMED_PAID
  CHECKED_IN
  CANCELLED
  REFUNDED
  COMPLETED
}

enum PaymentPlan {
  FULL
  DEPOSIT_50
  PAY_LATER
}

enum PayLaterStatus {
  SCHEDULED
  OVERDUE
  DEFAULTED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  INITIATED
  CAPTURED
  FAILED
  REFUNDED
}

enum PayoutStatus {
  NOT_ELIGIBLE
  ELIGIBLE
  SCHEDULED
  PAID
  ON_HOLD
  REVERSED
}

enum IssueCategory {
  MAINTENANCE
  CLEANLINESS
  NOISE
  SAFETY
  OTHER
}

enum IssueUrgency {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum LedgerEventType {
  PAYMENT_CAPTURED
  REFUND_ISSUED
  PAYOUT_SCHEDULED
  PAYOUT_SENT
  BALANCE_CARRY_FORWARD
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique
  passwordHash   String?
  fullName       String
  role           UserRole
  kind           UserKind?   // Phase 1: replaces role over time; null = not yet migrated
  isActive       Boolean     @default(true)
  auth0Sub       String?     @unique
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  phone          String?
  avatarUrl      String?
  // ── Relations ──────────────────────────────────────────────────────────────
  hostProfile    Host?
  staffRole      StaffRole?
  ownerProfile   OwnerProfile?
  investorProfile InvestorProfile?
  listings       Listing[]
  holds          Hold[]
  bookings       Booking[]
  auditLogs      AuditLog[]  @relation("AuditActor")
  wishlists      Wishlist[]
  reviews        Review[]
  guestNotifications GuestNotification[]
  guestPreference    GuestPreference?
  conversationsAsOne Conversation[]     @relation("ConversationsAsOne")
  conversationsAsTwo Conversation[]     @relation("ConversationsAsTwo")
  sentMessages       Message[]
  guestIssues        GuestIssue[]
  referralCode       String?     @unique
  referrals          Referral[]  @relation("ReferrerReferrals")
  referredBy         Referral?   @relation("ReferredUserReferral")
  creditLedger       CreditLedger[]
  // ── Phase 0 security ───────────────────────────────────────────────────────
  refreshFamilies RefreshTokenFamily[]
  sessions        Session[]
  mfaFactors      MfaFactor[]
  // ── Phase 2 add-ons ────────────────────────────────────────────────────────
  serviceProviders ServiceProvider[] @relation("ProviderOwner")
  // ── Phase 2 §5.13 rewards ─────────────────────────────────────────────────
  membership       Membership?
  tripSips         TripSip[]
  // ── Phase 2 §5.17 notifications ───────────────────────────────────────────
  notificationPreference NotificationPreference?
  notificationOutbox     NotificationOutbox[]
  // ── Phase 3 §5.12 SOS ─────────────────────────────────────────────────────
  trustedContacts  TrustedContact[]
  sosIncidents     SosIncident[]
  // ── Phase 3 §5.14 Investor dashboard ──────────────────────────────────────
  investments       Investment[]        @relation("InvestorInvestments")
  distributions     Distribution[]      @relation("InvestorDistributions")
  investorDocuments InvestorDocument[]  @relation("InvestorDocuments")
  investorDocsUploaded InvestorDocument[] @relation("InvestorDocUploader")
  // ── Phase 3 §5.15 Experiences ────────────────────────────────────────────
  experiencesCreated  Experience[]        @relation("ExperienceCreator")
  experienceBookings  ExperienceBooking[] @relation("ExperienceGuestBookings")
  // ── Phase 3 §5.8 Group Planning ──────────────────────────────────────────
  ownedTripGroups     TripGroup[]         @relation("TripGroupOwner")
  tripGroupMembers    TripGroupMember[]
  expensePayments     ExpenseSplitShare[] @relation("ExpenseShareUser")
  createdExpenses     ExpenseSplit[]      @relation("ExpenseCreator")
  // ── Phase 3 §5.9 AI Itinerary ────────────────────────────────────────────
  itineraries         Itinerary[]         @relation("ItineraryOwner")
  itineraryUsage      ItineraryUsage[]    @relation("ItineraryUsageOwner")
}

model Host {
  id                  String                 @id @default(cuid())
  userId              String                 @unique
  verificationStatus  HostVerificationStatus @default(PENDING)
  payoutAccountRef    String?
  payoutEnabled       Boolean                @default(false)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  user                User                   @relation(fields: [userId], references: [id])
  listings            Listing[]
  payoutLines         PayoutLine[]
  notifications       HostNotification[]
  quickReplies        HostQuickReply[]
  experiences         Experience[]
  settings            HostSetting?
}

model Listing {
  id                  String               @id @default(cuid())
  hostId              String
  createdById         String
  title               String
  description         String
  city                String
  state               String
  country             String               @default("India")
  latitude            Float?
  longitude           Float?
  timezone            String               @default("Asia/Kolkata")
  status              ListingStatus        @default(PENDING_APPROVAL)
  preparationGuide    Json?
  propertyDirections  Json?
  propertyManual      Json?
  experienceTags      String[]             @default([])
  propertyType        String?
  dietaryOptions      String[]             @default([])
  stayThemeId         String?              // Stay Pass visual identity (§Stay Pass module)
  needsReapproval     Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  host                Host                 @relation(fields: [hostId], references: [id])
  createdBy           User                 @relation(fields: [createdById], references: [id])
  media               ListingMedia[]
  tags                ListingTag[]
  rateRules           RateRule[]
  seasonalRates       SeasonalRate[]
  availabilityBlocks  AvailabilityBlock[]
  holds               Hold[]
  bookings            Booking[]
  payoutLines         PayoutLine[]
  wishlists           Wishlist[]
  reviews             Review[]
  conversations       Conversation[]
  issues               GuestIssue[]
  addOns              AddOn[]              @relation("ListingAddOns")
  investments         Investment[]
  capitalCalls        CapitalCall[]
  experiences         Experience[]         @relation("ListingExperiences")
  stayTheme           StayTheme?           @relation(fields: [stayThemeId], references: [id])

  @@index([hostId])
  @@index([status, createdAt])
}

model ListingMedia {
  id           String   @id @default(cuid())
  listingId    String
  url          String
  mediaType    String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Tag {
  id          String       @id @default(cuid())
  category    String
  name        String
  createdAt   DateTime     @default(now())
  listingTags ListingTag[]

  @@unique([category, name])
}

model ListingTag {
  listingId   String
  tagId       String
  listing     Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tag         Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([listingId, tagId])
}

model RateRule {
  id                String   @id @default(cuid())
  listingId         String
  baseNightlyRate   Int
  cleaningFee       Int      @default(0)
  minNights         Int      @default(1)
  maxGuests         Int      @default(2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  listing           Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model SeasonalRate {
  id              String   @id @default(cuid())
  listingId       String
  startsAt        DateTime
  endsAt          DateTime
  nightlyRate     Int
  createdAt       DateTime @default(now())
  listing         Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, startsAt, endsAt])
}

model AvailabilityBlock {
  id             String   @id @default(cuid())
  listingId      String
  startsAt       DateTime
  endsAt         DateTime
  reason         String
  createdAt      DateTime @default(now())
  listing        Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, startsAt, endsAt])
}

model Hold {
  id               String      @id @default(cuid())
  listingId        String
  guestId          String
  startsAt         DateTime
  endsAt           DateTime
  expiresAt        DateTime
  priceSnapshot    Json
  idempotencyKey   String      @unique
  createdAt        DateTime    @default(now())
  listing          Listing     @relation(fields: [listingId], references: [id])
  guest            User        @relation(fields: [guestId], references: [id])
  booking          Booking?

  @@index([listingId])
}

model Booking {
  id               String       @id @default(cuid())
  listingId        String
  guestId          String
  holdId           String       @unique
  status           BookingStatus @default(PAYMENT_PENDING)
  plan             PaymentPlan
  startsAt         DateTime
  endsAt           DateTime
  priceSnapshot    Json
  guestDetails     Json?
  checkInData      Json?
  checkOutData     Json?
  balanceDueAt     DateTime?
  payLaterMonths   Int?
  /** Timestamp when the guest accepted the cancellation policy + terms. Required at booking creation. */
  acceptedTermsAt  DateTime?
  /**
   * Append-only timeline of state transitions. Written by BookingStateMachine only.
   * Each entry: { from, to, event, actorId, at: ISO-8601, metadata? }.
   * Source of truth for dispute resolution and admin debugging.
   */
  statusHistory    Json         @default("[]")
  /**
   * Frozen cancellation-policy tiers, copied onto the booking at confirmation.
   * cancelBookingInternal reads from here, never from a live policy source.
   * Shape: { tiers: [{ minHoursBefore, refundPct }, ...] }.
   */
  cancellationPolicySnapshot Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  listing          Listing      @relation(fields: [listingId], references: [id])
  guest            User         @relation(fields: [guestId], references: [id])
  hold             Hold         @relation(fields: [holdId], references: [id])
  payments         Payment[]
  refunds          Refund[]
  review           Review?
  conversations    Conversation[]
  issues           GuestIssue[]
  addOns           BookingAddOn[]
  payLaterPlan     PayLaterPlan?
  sosIncidents     SosIncident[]
  ticket           Ticket?

  @@index([listingId, status])
  @@index([guestId, status])
  @@index([status, createdAt])
  @@index([listingId, startsAt, endsAt])
}

model Payment {
  id                 String        @id @default(cuid())
  bookingId          String
  amount             Int
  type               PaymentPlan
  status             PaymentStatus @default(INITIATED)
  gateway            String        @default("razorpay")
  gatewayPaymentRef  String?
  gatewayOrderRef    String?
  idempotencyKey     String        @unique
  /** When type = PAY_LATER, the instalment sequence this payment is paying. */
  payLaterSeq        Int?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  booking            Booking       @relation(fields: [bookingId], references: [id])
  payLaterInstalment PayLaterInstalment?

  @@index([bookingId])
  @@index([status, createdAt])
}

/**
 * Webhook event-ID dedup table for Razorpay.
 *
 * Razorpay delivers webhooks at-least-once (their own retry semantics + our
 * non-2xx replays). The unique constraint on `eventId` makes the very first
 * INSERT win and every subsequent INSERT fail — the handler exits clean on
 * the duplicate-key error and we never run the side effects twice.
 *
 * Inserted INSIDE the signature-verify path so attackers can't poison the
 * table with unsigned junk event IDs. The (signature → dedup-insert → handle)
 * order is invariant; see payment.service.handleWebhook.
 */
model ProcessedRazorpayEvent {
  eventId    String   @id
  /** Razorpay event type (payment.captured, payment.failed, refund.processed). */
  eventType  String
  receivedAt DateTime @default(now())

  @@index([receivedAt])
}

model PayLaterPlan {
  id            String               @id @default(cuid())
  bookingId     String               @unique
  months        Int
  totalMinor    Int
  status        PayLaterStatus       @default(SCHEDULED)
  currency      String               @default("INR")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  booking       Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  instalments   PayLaterInstalment[]

  @@index([status, createdAt])
}

model PayLaterInstalment {
  id            String        @id @default(cuid())
  planId        String
  seq           Int
  amountMinor   Int
  dueAt         DateTime
  paidAt        DateTime?
  paymentId     String?       @unique
  remindersSent Int           @default(0)
  lastReminderAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  plan          PayLaterPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  payment       Payment?      @relation(fields: [paymentId], references: [id])

  @@unique([planId, seq])
  @@index([dueAt, paidAt])
}

model Refund {
  id                 String        @id @default(cuid())
  bookingId          String
  paymentId          String?
  amount             Int
  reason             String
  gatewayRefundRef   String?
  createdAt          DateTime      @default(now())
  booking            Booking       @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model PayoutLine {
  id                 String       @id @default(cuid())
  hostId             String
  listingId          String
  bookingId          String
  amount             Int
  eligibleAt         DateTime
  status             PayoutStatus @default(NOT_ELIGIBLE)
  batchId            String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  host               Host         @relation(fields: [hostId], references: [id])
  listing            Listing      @relation(fields: [listingId], references: [id])
  batch              PayoutBatch? @relation(fields: [batchId], references: [id])

  @@index([hostId, status])
}

model PayoutBatch {
  id                 String       @id @default(cuid())
  runDate            DateTime
  status             PayoutStatus @default(SCHEDULED)
  totalAmount        Int          @default(0)
  createdAt          DateTime     @default(now())
  lines              PayoutLine[]
}

model LedgerEvent {
  id                 String          @id @default(cuid())
  bookingId          String?
  payoutLineId       String?
  type               LedgerEventType
  amount             Int
  currency           String          @default("INR")
  metadata           Json
  createdAt          DateTime        @default(now())

  @@index([bookingId])
}

model AuditLog {
  id                 String   @id @default(cuid())
  actorUserId        String?
  action             String
  resourceType       String
  resourceId         String
  metadata           Json
  createdAt          DateTime @default(now())
  actor              User?    @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([resourceType, resourceId])
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

/**
 * Platform feature flag override. The canonical set of flags lives in code
 * (feature-flags.registry.ts); this table holds only admin OVERRIDES of the
 * code-defined default. A missing row means "use the registry default".
 * Toggling a flag off makes the @FeatureGate guard reject the feature's API
 * with 503 and hides it in the UI.
 */
model FeatureFlag {
  key       String   @id
  enabled   Boolean
  updatedAt DateTime @updatedAt
  updatedBy String?
}

/**
 * Per-host control-panel settings. Host-owned toggles the host manages
 * themselves (distinct from platform feature flags set by admins).
 */
model HostSetting {
  hostId            String   @id
  /** Auto-confirm bookings without manual host review (forward-looking). */
  instantBook       Boolean  @default(false)
  /** Allow guests to start a direct message thread with this host. */
  allowGuestMessages Boolean @default(true)
  /** Allow guests to open a concierge chat on their booking. */
  allowConciergeChat Boolean @default(true)
  /** Email this host when a new booking lands. */
  emailOnNewBooking Boolean  @default(true)
  /** SMS this host when a new booking lands. */
  smsOnNewBooking   Boolean  @default(false)
  updatedAt         DateTime @updatedAt

  host              Host     @relation(fields: [hostId], references: [id], onDelete: Cascade)
}

model AdminNotification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  metadata  Json     @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
}

model HostNotification {
  id        String   @id @default(cuid())
  hostId    String
  type      String
  title     String
  message   String
  metadata  Json     @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  host      Host     @relation(fields: [hostId], references: [id])

  @@index([hostId, isRead, createdAt])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])

  @@unique([userId, listingId])
  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  userId    String
  listingId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
  booking   Booking  @relation(fields: [bookingId], references: [id])

  @@index([listingId])
  @@index([userId])
}

model GuestNotification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  metadata  Json     @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt])
}

enum ConversationKind {
  STANDARD
  CONCIERGE
}

enum ConversationStatus {
  OPEN
  CLOSED
}

model Conversation {
  id                 String             @id @default(cuid())
  type               String             // GUEST_HOST, HOST_ADMIN
  kind               ConversationKind   @default(STANDARD)
  status             ConversationStatus @default(OPEN)
  userOneId          String             // guest (GUEST_HOST) or host (HOST_ADMIN)
  userTwoId          String             // host (GUEST_HOST) or admin (HOST_ADMIN)
  listingId          String?
  bookingId          String?
  subject            String?
  lastGuestMessageAt DateTime?
  lastHostMessageAt  DateTime?
  slaDueAt           DateTime?
  slaBreachedAt      DateTime?
  closedAt           DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  userOne            User               @relation("ConversationsAsOne", fields: [userOneId], references: [id])
  userTwo            User               @relation("ConversationsAsTwo", fields: [userTwoId], references: [id])
  listing            Listing?           @relation(fields: [listingId], references: [id])
  booking            Booking?           @relation(fields: [bookingId], references: [id])
  messages           Message[]

  @@unique([userOneId, userTwoId, listingId])
  @@index([userOneId])
  @@index([userTwoId])
  @@index([type])
  @@index([kind, status])
  @@index([status, slaDueAt])
  @@index([bookingId, kind])
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  senderId        String
  senderRole      UserRole
  body            String
  isRead          Boolean      @default(false)
  isSystem        Boolean      @default(false)
  createdAt       DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversationId], references: [id])
  sender          User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}

model HostQuickReply {
  id        String   @id @default(cuid())
  hostId    String
  label     String
  body      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  host      Host     @relation(fields: [hostId], references: [id], onDelete: Cascade)

  @@index([hostId, sortOrder])
}

model GuestPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  dietaryNeeds      String[]
  wellnessInterests String[]
  accessibility     String?
  roomPreference    String?
  experienceLevel   String?
  arrivalPreference String?
  emergencyContact  Json?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  key          String   @unique
  userId       String
  requestPath  String
  requestHash  String
  status       String   @default("PROCESSING")
  httpStatus   Int?
  responseBody Json?
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([expiresAt])
}

model GuestIssue {
  id          String        @id @default(cuid())
  bookingId   String
  listingId   String
  guestId     String
  category    IssueCategory
  description String
  urgency     IssueUrgency  @default(MEDIUM)
  photoUrl    String?
  status      IssueStatus   @default(OPEN)
  hostNotes   String?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  booking     Booking       @relation(fields: [bookingId], references: [id])
  listing     Listing       @relation(fields: [listingId], references: [id])
  guest       User          @relation(fields: [guestId], references: [id])

  @@index([bookingId])
  @@index([listingId, status])
  @@index([guestId])
  @@index([status, createdAt])
}

enum ReferralStatus {
  PENDING
  SIGNED_UP
  FIRST_BOOKING
  CREDITED
}

model Referral {
  id              String         @id @default(cuid())
  referrerId      String
  referredUserId  String?        @unique
  referralCode    String         @unique
  status          ReferralStatus @default(PENDING)
  referrerCredit  Int            @default(0)
  referredCredit  Int            @default(0)
  creditedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  referrer        User           @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referredUser    User?          @relation("ReferredUserReferral", fields: [referredUserId], references: [id])

  @@index([referrerId])
}

model CreditLedger {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  reason      String
  referenceId String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  sipContribution SipContribution?

  @@index([userId, createdAt])
}

// ─── Phase 2 §5.13: Rewards & Membership ─────────────────────────────────────

enum MemberTier {
  EXPLORER
  WANDERER
  SOJOURNER
  PATRON
  AMBASSADOR
}

enum SipStatus {
  ACTIVE
  PAUSED
  CLOSED
}

model Membership {
  userId     String     @id
  tier       MemberTier @default(EXPLORER)
  points     Int        @default(0)
  tierSince  DateTime   @default(now())
  nextTierAt Int        @default(500)
  updatedAt  DateTime   @updatedAt
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tier])
}

model TripSip {
  id            String            @id @default(cuid())
  userId        String
  monthlyMinor  Int
  anchorDay     Int               @default(1) // 1..28 day-of-month for autodebit
  startedAt     DateTime          @default(now())
  closedAt      DateTime?
  status        SipStatus         @default(ACTIVE)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions SipContribution[]

  @@index([userId, status])
  @@index([status, anchorDay])
}

model SipContribution {
  id              String       @id @default(cuid())
  sipId           String
  amountMinor     Int
  depositedAt     DateTime     @default(now())
  ledgerEventId   String       @unique // 1:1 with CreditLedger row
  paymentRef      String?      // razorpay payment id for reconciliation
  sip             TripSip      @relation(fields: [sipId], references: [id], onDelete: Cascade)
  ledgerEvent     CreditLedger @relation(fields: [ledgerEventId], references: [id], onDelete: Restrict)

  @@index([sipId, depositedAt])
}

model Perk {
  id          String     @id @default(cuid())
  tier        MemberTier
  title       String
  description String
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tier, active])
}

// ─── Phase 0: Refresh token family tracking ───────────────────────────────────

model RefreshTokenFamily {
  id           String         @id @default(cuid())
  userId       String
  createdAt    DateTime       @default(now())
  revokedAt    DateTime?
  revokeReason String?
  user         User           @relation(fields: [userId], references: [id])
  tokens       RefreshToken[]

  @@index([userId])
}

model RefreshToken {
  id         String             @id @default(cuid())
  familyId   String
  tokenHash  String             // SHA-256 of raw JTI
  issuedAt   DateTime           @default(now())
  expiresAt  DateTime
  rotatedTo  String?            // id of the next token in the chain
  usedAt     DateTime?          // set on rotation; reuse after this = theft
  ipAddress  String?
  userAgent  String?
  family     RefreshTokenFamily @relation(fields: [familyId], references: [id])

  @@unique([tokenHash])
  @@index([familyId])
  @@index([expiresAt])
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  familyId  String    // links to a RefreshTokenFamily
  device    String
  ipAddress String
  lastSeen  DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model MfaFactor {
  id        String   @id @default(cuid())
  userId    String
  type      MfaType
  secret    String   // TOTP: base32-encoded secret
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, type])
  @@index([userId])
}

// ─── Phase 1: Extended identity models ───────────────────────────────────────

model StaffRole {
