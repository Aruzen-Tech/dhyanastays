generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Legacy role enum (kept for JWT backward-compat and Message.senderRole) ───
enum UserRole {
  GUEST
  HOST
  ADMIN
}

// ─── Phase 1: expanded identity model ────────────────────────────────────────

enum UserKind {
  GUEST
  OWNER      // property operator (maps from HOST)
  INVESTOR   // capital provider
  STAFF      // internal team (maps from ADMIN)
}

enum AdminLevel {
  L1 // Super Admin
  L2 // Operational Admin
  L3 // Cluster / Regional Admin
  L4 // Property-Level Admin
  L5 // Service-Level Admin
}

enum ServiceType {
  TRANSPORT
  FOOD
  WELLNESS
  EXPERIENCE
  CONCIERGE
  HOUSEKEEPING
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MfaType {
  TOTP
  SMS
  EMAIL
}

enum HostVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum BookingStatus {
  HOLD
  PAYMENT_PENDING
  CONFIRMED_DEPOSIT
  BALANCE_DUE
  CONFIRMED_PAID
  CANCELLED
  REFUNDED
  COMPLETED
}

enum PaymentPlan {
  FULL
  DEPOSIT_50
  PAY_LATER
}

enum PayLaterStatus {
  SCHEDULED
  OVERDUE
  DEFAULTED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  INITIATED
  CAPTURED
  FAILED
  REFUNDED
}

enum PayoutStatus {
  NOT_ELIGIBLE
  ELIGIBLE
  SCHEDULED
  PAID
  ON_HOLD
  REVERSED
}

enum IssueCategory {
  MAINTENANCE
  CLEANLINESS
  NOISE
  SAFETY
  OTHER
}

enum IssueUrgency {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum LedgerEventType {
  PAYMENT_CAPTURED
  REFUND_ISSUED
  PAYOUT_SCHEDULED
  PAYOUT_SENT
  BALANCE_CARRY_FORWARD
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique
  passwordHash   String?
  fullName       String
  role           UserRole
  kind           UserKind?   // Phase 1: replaces role over time; null = not yet migrated
  isActive       Boolean     @default(true)
  auth0Sub       String?     @unique
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  phone          String?
  avatarUrl      String?
  // ── Relations ──────────────────────────────────────────────────────────────
  hostProfile    Host?
  staffRole      StaffRole?
  ownerProfile   OwnerProfile?
  investorProfile InvestorProfile?
  listings       Listing[]
  holds          Hold[]
  bookings       Booking[]
  auditLogs      AuditLog[]  @relation("AuditActor")
  wishlists      Wishlist[]
  reviews        Review[]
  guestNotifications GuestNotification[]
  guestPreference    GuestPreference?
  conversationsAsOne Conversation[]     @relation("ConversationsAsOne")
  conversationsAsTwo Conversation[]     @relation("ConversationsAsTwo")
  sentMessages       Message[]
  guestIssues        GuestIssue[]
  referralCode       String?     @unique
  referrals          Referral[]  @relation("ReferrerReferrals")
  referredBy         Referral?   @relation("ReferredUserReferral")
  creditLedger       CreditLedger[]
  // ── Phase 0 security ───────────────────────────────────────────────────────
  refreshFamilies RefreshTokenFamily[]
  sessions        Session[]
  mfaFactors      MfaFactor[]
  // ── Phase 2 add-ons ────────────────────────────────────────────────────────
  serviceProviders ServiceProvider[] @relation("ProviderOwner")
  // ── Phase 2 §5.13 rewards ─────────────────────────────────────────────────
  membership       Membership?
  tripSips         TripSip[]
  // ── Phase 2 §5.17 notifications ───────────────────────────────────────────
  notificationPreference NotificationPreference?
  notificationOutbox     NotificationOutbox[]
  // ── Phase 3 §5.12 SOS ─────────────────────────────────────────────────────
  trustedContacts  TrustedContact[]
  sosIncidents     SosIncident[]
}

model Host {
  id                  String                 @id @default(cuid())
  userId              String                 @unique
  verificationStatus  HostVerificationStatus @default(PENDING)
  payoutAccountRef    String?
  payoutEnabled       Boolean                @default(false)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  user                User                   @relation(fields: [userId], references: [id])
  listings            Listing[]
  payoutLines         PayoutLine[]
  notifications       HostNotification[]
}

model Listing {
  id                  String               @id @default(cuid())
  hostId              String
  createdById         String
  title               String
  description         String
  city                String
  state               String
  country             String               @default("India")
  latitude            Float?
  longitude           Float?
  timezone            String               @default("Asia/Kolkata")
  status              ListingStatus        @default(PENDING_APPROVAL)
  preparationGuide    Json?
  propertyDirections  Json?
  propertyManual      Json?
  needsReapproval     Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  host                Host                 @relation(fields: [hostId], references: [id])
  createdBy           User                 @relation(fields: [createdById], references: [id])
  media               ListingMedia[]
  tags                ListingTag[]
  rateRules           RateRule[]
  seasonalRates       SeasonalRate[]
  availabilityBlocks  AvailabilityBlock[]
  holds               Hold[]
  bookings            Booking[]
  payoutLines         PayoutLine[]
  wishlists           Wishlist[]
  reviews             Review[]
  conversations       Conversation[]
  issues               GuestIssue[]
  addOns              AddOn[]              @relation("ListingAddOns")

  @@index([hostId])
  @@index([status, createdAt])
}

model ListingMedia {
  id           String   @id @default(cuid())
  listingId    String
  url          String
  mediaType    String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Tag {
  id          String       @id @default(cuid())
  category    String
  name        String
  createdAt   DateTime     @default(now())
  listingTags ListingTag[]

  @@unique([category, name])
}

model ListingTag {
  listingId   String
  tagId       String
  listing     Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tag         Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([listingId, tagId])
}

model RateRule {
  id                String   @id @default(cuid())
  listingId         String
  baseNightlyRate   Int
  cleaningFee       Int      @default(0)
  minNights         Int      @default(1)
  maxGuests         Int      @default(2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  listing           Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model SeasonalRate {
  id              String   @id @default(cuid())
  listingId       String
  startsAt        DateTime
  endsAt          DateTime
  nightlyRate     Int
  createdAt       DateTime @default(now())
  listing         Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, startsAt, endsAt])
}

model AvailabilityBlock {
  id             String   @id @default(cuid())
  listingId      String
  startsAt       DateTime
  endsAt         DateTime
  reason         String
  createdAt      DateTime @default(now())
  listing        Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, startsAt, endsAt])
}

model Hold {
  id               String      @id @default(cuid())
  listingId        String
  guestId          String
  startsAt         DateTime
  endsAt           DateTime
  expiresAt        DateTime
  priceSnapshot    Json
  idempotencyKey   String      @unique
  createdAt        DateTime    @default(now())
  listing          Listing     @relation(fields: [listingId], references: [id])
  guest            User        @relation(fields: [guestId], references: [id])
  booking          Booking?

  @@index([listingId])
}

model Booking {
  id               String       @id @default(cuid())
  listingId        String
  guestId          String
  holdId           String       @unique
  status           BookingStatus @default(PAYMENT_PENDING)
  plan             PaymentPlan
  startsAt         DateTime
  endsAt           DateTime
  priceSnapshot    Json
  guestDetails     Json?
  checkInData      Json?
  checkOutData     Json?
  balanceDueAt     DateTime?
  payLaterMonths   Int?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  listing          Listing      @relation(fields: [listingId], references: [id])
  guest            User         @relation(fields: [guestId], references: [id])
  hold             Hold         @relation(fields: [holdId], references: [id])
  payments         Payment[]
  refunds          Refund[]
  review           Review?
  conversations    Conversation[]
  issues           GuestIssue[]
  addOns           BookingAddOn[]
  payLaterPlan     PayLaterPlan?
  sosIncidents     SosIncident[]

  @@index([listingId, status])
  @@index([guestId, status])
  @@index([status, createdAt])
  @@index([listingId, startsAt, endsAt])
}

model Payment {
  id                 String        @id @default(cuid())
  bookingId          String
  amount             Int
  type               PaymentPlan
  status             PaymentStatus @default(INITIATED)
  gateway            String        @default("razorpay")
  gatewayPaymentRef  String?
  gatewayOrderRef    String?
  idempotencyKey     String        @unique
  /** When type = PAY_LATER, the instalment sequence this payment is paying. */
  payLaterSeq        Int?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  booking            Booking       @relation(fields: [bookingId], references: [id])
  payLaterInstalment PayLaterInstalment?

  @@index([bookingId])
  @@index([status, createdAt])
}

model PayLaterPlan {
  id            String               @id @default(cuid())
  bookingId     String               @unique
  months        Int
  totalMinor    Int
  status        PayLaterStatus       @default(SCHEDULED)
  currency      String               @default("INR")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  booking       Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  instalments   PayLaterInstalment[]

  @@index([status, createdAt])
}

model PayLaterInstalment {
  id            String        @id @default(cuid())
  planId        String
  seq           Int
  amountMinor   Int
  dueAt         DateTime
  paidAt        DateTime?
  paymentId     String?       @unique
  remindersSent Int           @default(0)
  lastReminderAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  plan          PayLaterPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  payment       Payment?      @relation(fields: [paymentId], references: [id])

  @@unique([planId, seq])
  @@index([dueAt, paidAt])
}

model Refund {
  id                 String        @id @default(cuid())
  bookingId          String
  paymentId          String?
  amount             Int
  reason             String
  gatewayRefundRef   String?
  createdAt          DateTime      @default(now())
  booking            Booking       @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model PayoutLine {
  id                 String       @id @default(cuid())
  hostId             String
  listingId          String
  bookingId          String
  amount             Int
  eligibleAt         DateTime
  status             PayoutStatus @default(NOT_ELIGIBLE)
  batchId            String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  host               Host         @relation(fields: [hostId], references: [id])
  listing            Listing      @relation(fields: [listingId], references: [id])
  batch              PayoutBatch? @relation(fields: [batchId], references: [id])

  @@index([hostId, status])
}

model PayoutBatch {
  id                 String       @id @default(cuid())
  runDate            DateTime
  status             PayoutStatus @default(SCHEDULED)
  totalAmount        Int          @default(0)
  createdAt          DateTime     @default(now())
  lines              PayoutLine[]
}

model LedgerEvent {
  id                 String          @id @default(cuid())
  bookingId          String?
  payoutLineId       String?
  type               LedgerEventType
  amount             Int
  currency           String          @default("INR")
  metadata           Json
  createdAt          DateTime        @default(now())

  @@index([bookingId])
}

model AuditLog {
  id                 String   @id @default(cuid())
  actorUserId        String?
  action             String
  resourceType       String
  resourceId         String
  metadata           Json
  createdAt          DateTime @default(now())
  actor              User?    @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([resourceType, resourceId])
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model AdminNotification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  metadata  Json     @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
}

model HostNotification {
  id        String   @id @default(cuid())
  hostId    String
  type      String
  title     String
  message   String
  metadata  Json     @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  host      Host     @relation(fields: [hostId], references: [id])

  @@index([hostId, isRead, createdAt])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])

  @@unique([userId, listingId])
  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  userId    String
  listingId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
  booking   Booking  @relation(fields: [bookingId], references: [id])

  @@index([listingId])
  @@index([userId])
}

model GuestNotification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  metadata  Json     @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt])
}

model Conversation {
  id          String    @id @default(cuid())
  type        String    // GUEST_HOST, HOST_ADMIN
  userOneId   String    // guest (GUEST_HOST) or host (HOST_ADMIN)
  userTwoId   String    // host (GUEST_HOST) or admin (HOST_ADMIN)
  listingId   String?
  bookingId   String?
  subject     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userOne     User      @relation("ConversationsAsOne", fields: [userOneId], references: [id])
  userTwo     User      @relation("ConversationsAsTwo", fields: [userTwoId], references: [id])
  listing     Listing?  @relation(fields: [listingId], references: [id])
  booking     Booking?  @relation(fields: [bookingId], references: [id])
  messages    Message[]

  @@unique([userOneId, userTwoId, listingId])
  @@index([userOneId])
  @@index([userTwoId])
  @@index([type])
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  senderId        String
  senderRole      UserRole
  body            String
  isRead          Boolean      @default(false)
  createdAt       DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversationId], references: [id])
  sender          User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}

model GuestPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  dietaryNeeds      String[]
  wellnessInterests String[]
  accessibility     String?
  roomPreference    String?
  experienceLevel   String?
  arrivalPreference String?
  emergencyContact  Json?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  key          String   @unique
  userId       String
  requestPath  String
  requestHash  String
  status       String   @default("PROCESSING")
  httpStatus   Int?
  responseBody Json?
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([expiresAt])
}

model GuestIssue {
  id          String        @id @default(cuid())
  bookingId   String
  listingId   String
  guestId     String
  category    IssueCategory
  description String
  urgency     IssueUrgency  @default(MEDIUM)
  photoUrl    String?
  status      IssueStatus   @default(OPEN)
  hostNotes   String?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  booking     Booking       @relation(fields: [bookingId], references: [id])
  listing     Listing       @relation(fields: [listingId], references: [id])
  guest       User          @relation(fields: [guestId], references: [id])

  @@index([bookingId])
  @@index([listingId, status])
  @@index([guestId])
  @@index([status, createdAt])
}

enum ReferralStatus {
  PENDING
  SIGNED_UP
  FIRST_BOOKING
  CREDITED
}

model Referral {
  id              String         @id @default(cuid())
  referrerId      String
  referredUserId  String?        @unique
  referralCode    String         @unique
  status          ReferralStatus @default(PENDING)
  referrerCredit  Int            @default(0)
  referredCredit  Int            @default(0)
  creditedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  referrer        User           @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referredUser    User?          @relation("ReferredUserReferral", fields: [referredUserId], references: [id])

  @@index([referrerId])
}

model CreditLedger {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  reason      String
  referenceId String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  sipContribution SipContribution?

  @@index([userId, createdAt])
}

// ─── Phase 2 §5.13: Rewards & Membership ─────────────────────────────────────

enum MemberTier {
  EXPLORER
  WANDERER
  SOJOURNER
  PATRON
  AMBASSADOR
}

enum SipStatus {
  ACTIVE
  PAUSED
  CLOSED
}

model Membership {
  userId     String     @id
  tier       MemberTier @default(EXPLORER)
  points     Int        @default(0)
  tierSince  DateTime   @default(now())
  nextTierAt Int        @default(500)
  updatedAt  DateTime   @updatedAt
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tier])
}

model TripSip {
  id            String            @id @default(cuid())
  userId        String
  monthlyMinor  Int
  anchorDay     Int               @default(1) // 1..28 day-of-month for autodebit
  startedAt     DateTime          @default(now())
  closedAt      DateTime?
  status        SipStatus         @default(ACTIVE)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions SipContribution[]

  @@index([userId, status])
  @@index([status, anchorDay])
}

model SipContribution {
  id              String       @id @default(cuid())
  sipId           String
  amountMinor     Int
  depositedAt     DateTime     @default(now())
  ledgerEventId   String       @unique // 1:1 with CreditLedger row
  paymentRef      String?      // razorpay payment id for reconciliation
  sip             TripSip      @relation(fields: [sipId], references: [id], onDelete: Cascade)
  ledgerEvent     CreditLedger @relation(fields: [ledgerEventId], references: [id], onDelete: Restrict)

  @@index([sipId, depositedAt])
}

model Perk {
  id          String     @id @default(cuid())
  tier        MemberTier
  title       String
  description String
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tier, active])
}

// ─── Phase 0: Refresh token family tracking ───────────────────────────────────

model RefreshTokenFamily {
  id           String         @id @default(cuid())
  userId       String
  createdAt    DateTime       @default(now())
  revokedAt    DateTime?
  revokeReason String?
  user         User           @relation(fields: [userId], references: [id])
  tokens       RefreshToken[]

  @@index([userId])
}

model RefreshToken {
  id         String             @id @default(cuid())
  familyId   String
  tokenHash  String             // SHA-256 of raw JTI
  issuedAt   DateTime           @default(now())
  expiresAt  DateTime
  rotatedTo  String?            // id of the next token in the chain
  usedAt     DateTime?          // set on rotation; reuse after this = theft
  ipAddress  String?
  userAgent  String?
  family     RefreshTokenFamily @relation(fields: [familyId], references: [id])

  @@unique([tokenHash])
  @@index([familyId])
  @@index([expiresAt])
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  familyId  String    // links to a RefreshTokenFamily
  device    String
  ipAddress String
  lastSeen  DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model MfaFactor {
  id        String   @id @default(cuid())
  userId    String
  type      MfaType
  secret    String   // TOTP: base32-encoded secret
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, type])
  @@index([userId])
}

// ─── Phase 1: Extended identity models ───────────────────────────────────────

model StaffRole {
  userId      String       @id
  level       AdminLevel
  clusterId   String?
  propertyId  String?
  serviceType ServiceType?
  createdAt   DateTime     @default(now())
  revokedAt   DateTime?
  createdBy   String       // promoter's userId
  user        User         @relation(fields: [userId], references: [id])

  @@index([level])
}

model OwnerProfile {
  userId    String    @id
  legalName String
  gstin     String?
  kycStatus KycStatus @default(PENDING)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id])
}

model InvestorProfile {
  userId     String    @id
  legalName  String
  panMasked  String?
  kycStatus  KycStatus @default(PENDING)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id])
}

model RoleChangeAudit {
  id           String   @id @default(cuid())
  targetUserId String
  actorUserId  String
  before       Json
  after        Json
  reason       String
  createdAt    DateTime @default(now())

  @@index([targetUserId])
  @@index([actorUserId])
}

// ─── Staff applications (admin registration) ──────────────────────────────────

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model StaffApplication {
  id               String            @id @default(cuid())
  applicantId      String?           // linked user if already registered
  email            String
  fullName         String
  requestedLevel   AdminLevel
  requestedService ServiceType?      // L5 only
  clusterId        String?           // L3 context
  propertyId       String?           // L4 context
  justification    String
  status           ApplicationStatus @default(PENDING)
  reviewedBy       String?           // L1 userId who acted
  reviewNotes      String?
  reviewedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([applicantId])
}

// ─── Pre-booking add-ons (Phase 2 §5.7) ───────────────────────────────────────

enum CancellationTier {
  FLEXIBLE        // full refund up to 24h before check-in
  MODERATE        // 50% refund 24-72h, 0% inside 24h
  STRICT          // 50% refund up to 7d, 0% inside 7d
  NON_REFUNDABLE  // no refund once confirmed
}

enum AddOnScope {
  GLOBAL    // applies to all listings
  CLUSTER   // applies within a cluster (future)
  LISTING   // applies to a single listing
}

enum AddOnStatus {
  PENDING   // awaiting admin approval
  APPROVED  // visible to guests
  REJECTED
  RETIRED   // no longer bookable (historical)
}

enum AddOnState {
  QUOTED
  HELD
  CONFIRMED
  DELIVERED
  CANCELLED
  REFUNDED
}

model ServiceProvider {
  id           String       @id @default(cuid())
  name         String
  kind         ServiceType
  ownerUserId  String
  contactEmail String?
  contactPhone String?
  payoutMethod Json?
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  owner        User         @relation("ProviderOwner", fields: [ownerUserId], references: [id])
  addOns       AddOn[]

  @@index([ownerUserId])
  @@index([kind, active])
}

model AddOn {
  id               String           @id @default(cuid())
  providerId       String
  title            String
  description      String
  priceMinor       Int              // paise — per unit
  commissionRate   Float            @default(0.15) // platform cut (0–1)
  currency         String           @default("INR")
  cancellationTier CancellationTier @default(MODERATE)
  minLeadHours     Int              @default(24)
  maxPerBooking    Int              @default(1)
  availability     Json?            // free-form rules (days of week, capacity, etc.)
  scope            AddOnScope       @default(GLOBAL)
  clusterId        String?
  listingId        String?
  status           AddOnStatus      @default(PENDING)
  reviewedBy       String?
  reviewNotes      String?
  reviewedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  provider         ServiceProvider  @relation(fields: [providerId], references: [id])
  listing          Listing?         @relation("ListingAddOns", fields: [listingId], references: [id])
  bookingAddOns    BookingAddOn[]

  @@index([providerId])
  @@index([status, scope])
  @@index([listingId])
}

model BookingAddOn {
  id            String     @id @default(cuid())
  bookingId     String
  addOnId       String
  providerId    String
  quantity      Int        @default(1)
  unitPrice     Int        // paise — snapshot
  totalPrice    Int        // paise — unitPrice * quantity, snapshot
  commission    Int        // paise — platform cut, snapshot
  providerShare Int        // paise — totalPrice - commission, snapshot
  state         AddOnState @default(QUOTED)
  snapshotHmac  String     // signed slice identifying this add-on in the price snapshot
  cancelledAt   DateTime?
  refundedAt    DateTime?
  refundAmount  Int?       // paise — actual refund given, if any
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  booking       Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addOn         AddOn      @relation(fields: [addOnId], references: [id])

  @@index([bookingId])
  @@index([addOnId, state])
  @@index([providerId, state])
}

// ─── Phase 2 §5.17 — Notification outbox + preferences ──────────────────────

enum OutboxStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  IN_APP
}

model NotificationPreference {
  userId     String   @id
  channels   Json     @default("{}")
  quietHours Json?
  updatedAt  DateTime @default(now()) @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationOutbox {
  id            String              @id @default(cuid())
  userId        String
  kind          String
  channel       NotificationChannel
  payload       Json
  status        OutboxStatus        @default(PENDING)
  attempts      Int                 @default(0)
  lastError     String?
  nextAttemptAt DateTime            @default(now())
  sentAt        DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([userId, createdAt(sort: Desc)])
  @@index([kind, createdAt(sort: Desc)])
}

// ── Phase 3 §5.12 SOS & support ────────────────────────────────────────────

enum SosTier {
  MEDICAL
  SECURITY
  TRANSPORT
  OTHER
}

enum SosStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  FALSE_ALARM
}

model TrustedContact {
  id        String   @id @default(cuid())
  userId    String
  name      String
  phone     String
  relation  String
  primary   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SosIncident {
  id          String       @id @default(cuid())
  userId      String
  bookingId   String?
  tier        SosTier
  lat         Float
  lng         Float
  message     String?
  status      SosStatus    @default(OPEN)
  openedAt    DateTime     @default(now())
  ackedAt     DateTime?
  ackedBy     String?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  booking     Booking?     @relation(fields: [bookingId], references: [id])
  broadcasts  SosBroadcast[]

  @@index([userId])
  @@index([status, openedAt(sort: Desc)])
  @@index([bookingId])
}

model SosBroadcast {
  id         String      @id @default(cuid())
  incidentId String
  channel    String
  target     String
  status     String      @default("QUEUED")
  lastError  String?
  sentAt     DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  incident   SosIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
}