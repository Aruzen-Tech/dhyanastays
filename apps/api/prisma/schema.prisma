// ── Phase 3 §5.9 AI Itinerary planner ───────────────────────────────────────

enum ItineraryStatus {
  DRAFT
  GENERATED
  FINALIZED
}

model Itinerary {
  id              String              @id @default(cuid())
  userId          String
  listingId       String?
  destination     String
  startsAt        DateTime
  endsAt          DateTime
  travelers       Int                 @default(2)
  interests       String[]            @default([])
  budgetMinor     Int?
  /** Optional theme/concept the user picked from suggestions, e.g. "Detox & Yoga". */
  themeHint       String?
  status          ItineraryStatus     @default(DRAFT)
  summary         String?
  days            Json?               // [{ day: 1, date, title, sessions: [{ time, title, description, category }] }]
  model           String?
  /** Cumulative input + output token counts for cost reporting. */
  tokensInput     Int                 @default(0)
  tokensOutput    Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user            User                @relation("ItineraryOwner", fields: [userId], references: [id])
  messages        ItineraryMessage[]

  @@index([userId, createdAt(sort: Desc)])
}

/**
 * Chat history for refining an existing itinerary. The assistant can either
 * reply text-only OR include a structured patch that mutates `Itinerary.days`.
 * `appliedPatch` records what was applied (audit trail for the mutation).
 */
model ItineraryMessage {
  id           String    @id @default(cuid())
  itineraryId  String
  role         String    // 'user' | 'assistant'
  content      String
  /** When the assistant response included a structured change to the itinerary days. */
  appliedPatch Json?
  /** Per-message token counts (for cost tracking). */
  tokensInput  Int       @default(0)
  tokensOutput Int       @default(0)
  createdAt    DateTime  @default(now())

  itinerary    Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([itineraryId, createdAt])
}

/**
 * Per-user, per-month usage counter for the AI itinerary planner. Drives the
 * cost cap (ITINERARY_USER_MONTHLY_CAP_PAISE). Idempotent via the (userId,
 * monthBucket) unique index — the service uses an upsert on every call.
 */
model ItineraryUsage {
  id            String   @id @default(cuid())
  userId        String
  /** YYYY-MM bucket — e.g. "2026-05". Resets monthly. */
  monthBucket   String
  generations   Int      @default(0)
  chatMessages  Int      @default(0)
  tokensInput   Int      @default(0)
  tokensOutput  Int      @default(0)
  /** Cumulative cost for the month in paise (computed from token totals at write time). */
  costPaise     Int      @default(0)
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  user          User     @relation("ItineraryUsageOwner", fields: [userId], references: [id])

  @@unique([userId, monthBucket])
  @@index([monthBucket])
}

// ─────────────────────────────────────────────────────────────────────────────
// Stay Pass module — themed tickets, signed-QR check-in, Stay Passport
// ─────────────────────────────────────────────────────────────────────────────

enum TicketStatus {
  PENDING
  RENDERED
  FAILED
  VOIDED
  COMMEMORATIVE
}

/// A visual identity bundle assigned to a listing. `id` is the theme key
/// (e.g. 'forest_villa'); `version` bumps on publish. Tickets snapshot the
/// version they were issued under; rendered assets are frozen immutably in S3.
model StayTheme {
  id          String    @id            // 'forest_villa', 'heritage', ...
  version     Int       @default(1)
  displayName String
  status      String    @default("ACTIVE") // DRAFT | ACTIVE | RETIRED
  tokens      Json                          // palette, motif, mood_line, stamp_shape…
  assets      Json      @default("{}")      // S3 keys: motif, pattern, icon, wallet strips
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  listings    Listing[]
}

/// A scarce, campaign-bound theme overlay. Serials claimed atomically.
model TicketEdition {
  id           String   @id            // 'pongal_2027'
  themeOverlay Json                    // palette/motif/border overrides
  windowStart  DateTime                // bookings confirmed in [start, end) get the edition
  windowEnd    DateTime
  scope        Json?                   // optional { propertyIds?, themeIds? } filter
  maxIssue     Int?                    // NULL = unlimited
  issuedCount  Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([windowStart, windowEnd])
}

/// One ticket per booking. `assets` is the render manifest (format → key).
model Ticket {
  id              String       @id @default(cuid())
  bookingId       String       @unique
  themeId         String
  themeVersion    Int
  editionId       String?
  editionSerial   Int?
  templateVersion Int          @default(1)
  status          TicketStatus @default(PENDING)
  assets          Json         @default("{}")
  qrJti           String       @unique      // single-issue id, supports revocation
  qrRevoked       Boolean      @default(false)
  wallet          Json         @default("{}") // apple serial / google object id, issued flags
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  booking         Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([themeId])
}

/// Append-only log of every check-in scan attempt (success and failure).
model CheckinScan {
  id        String   @id @default(cuid())
  bookingId String
  ticketId  String?
  scannedBy String   // host/admin userId
  result    String   // OK | INVALID_SIG | EXPIRED | NOT_YET | REVOKED | ALREADY_CHECKED_IN | NOT_OWNER | BAD_STATE
  scannedAt DateTime @default(now())

  @@index([bookingId])
}

/// One stamp per stay, self-contained (survives listing edits/deletions).
/// Lifecycle: minted at VERIFIED check-in (checkedInAt set) → sealed at
/// successful check-out (completedAt set). Stays that are never QR-scanned
/// still get a sealed stamp when the booking completes (backstop mint).
model PassportStamp {
  id           String    @id @default(cuid())
  guestId      String
  bookingId    String    @unique
  themeId      String
  editionId    String?
  propertyName String
  city         String
  stayStart    DateTime
  stayEnd      DateTime
  nights       Int
  checkedInAt  DateTime? // verified arrival (QR scan) — null when never scanned
  completedAt  DateTime? // sealed at check-out — null while the stay is in progress
  mintedAt     DateTime  @default(now())

  @@index([guestId, mintedAt])
}

/// Data-defined collection sets (e.g. "The Curator's Circuit").
model CollectionSet {
  id         String   @id            // 'all_stay_types_v1'
  definition Json                    // required theme/edition predicates
  reward     Json                    // { couponRef | tierBump | perk }
  createdAt  DateTime @default(now())
}

/// A guest's award for completing a collection set (idempotent per set).
model CollectionAward {
  guestId   String
  setId     String
  awardedAt DateTime @default(now())

  @@id([guestId, setId])
}