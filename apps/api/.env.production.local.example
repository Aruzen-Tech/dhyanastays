# ─────────────────────────────────────────────────────────────────────────────
# Dhyana Stays — API Production Environment (Cloudflare + Neon + Upstash)
# Copy to .env.production.local and fill in your real credentials.
# See docs/cloudflare-deployment.md for setup instructions.
# ─────────────────────────────────────────────────────────────────────────────

# ── App
NODE_ENV=production
PORT=3001
TZ=Asia/Kolkata
API_URL=https://api.dhyanastays.in
WEB_URL=https://dhyanastays.in

# ── Database (Neon / Supabase — NOT Cloudflare D1)
# Neon: https://neon.tech → project → Connection Details → copy URI
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xyz.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ── JWT — generate strong secrets (NEVER reuse between envs):
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_64_char_random_hex
JWT_REFRESH_SECRET=CHANGE_ME_different_64_char_random_hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis (Upstash — serverless, free tier)
# Upstash: https://upstash.com → Create database → copy Redis URL
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379
REDIS_HOST=HOST.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=PASSWORD

# ── Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
ALLOWED_ORIGINS=https://dhyanastays.in

# ── Razorpay
# Test keys: rzp_test_xxx (no KYC needed)
# Live keys: rzp_live_xxx (KYC required)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# ── Email (Resend recommended — resend.com)
EMAIL_PROVIDER=resend
EMAIL_FROM=noreply@dhyanastays.in
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── SMS (MSG91 for India — msg91.com)
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=xxxxxxxxxxxxxxxxxxxx
MSG91_SENDER_ID=DHYANA
MSG91_BOOKING_TEMPLATE_ID=CHANGE_ME
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Storage (Cloudflare R2)
# R2 dashboard: Cloudflare → R2 → Manage R2 API Tokens → Create Token
# Account ID: Cloudflare dashboard → right sidebar
STORAGE_PROVIDER=r2
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_BUCKET=dhyana-stays-media
S3_REGION=auto
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
CDN_URL=https://media.dhyanastays.in

# ── Auth0 (leave blank for custom JWT mode)
AUTH0_DOMAIN=
AUTH0_AUDIENCE=

# ── Meilisearch (cloud.meilisearch.com or self-hosted)
MEILI_URL=https://ms-xxxxxxxx.sfo.meilisearch.io
MEILI_MASTER_KEY=CHANGE_ME
