# ─────────────────────────────────────────────────────────────────────────────
# Dhyana Stays — API Environment Template (apps/api/.env.example)
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
TZ=Asia/Kolkata
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# For local Docker: postgresql://dhyana:dhyana@localhost:5432/dhyana_stays
DATABASE_URL=postgresql://dhyana:dhyana@localhost:5432/dhyana_stays

# ── JWT (Custom auth mode — used when AUTH0_DOMAIN is empty) ─────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=change-me-min-16-chars-access
JWT_REFRESH_SECRET=change-me-min-16-chars-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used by BullMQ for background jobs (hold expiry, payout batch, etc.)
# For local Docker: redis://localhost:6379
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# THROTTLE_TTL: window in milliseconds (default: 60000 = 1 minute)
# THROTTLE_LIMIT: max requests per window per IP (default: 100)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
ALLOWED_ORIGINS=http://localhost:3000

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use test mode keys for development (prefix: rzp_test_)
RAZORPAY_KEY_ID=rzp_test_TE6cUeGdT3qzRE
RAZORPAY_KEY_SECRET=oq4eUty97FFTyd8tsMmMT5Ka
# Webhook secret: Razorpay Dashboard → Webhooks → your webhook → Secret
RAZORPAY_WEBHOOK_SECRET=6bd72dfdb50304edaa60769b39a9da7ca048c1232ec0f65b

# ── Email ─────────────────────────────────────────────────────────────────────
# Provider options: stub | resend | sendgrid | smtp
# Use 'stub' for local development (logs emails to console, no real sending)
EMAIL_PROVIDER=stub
EMAIL_FROM=noreply@dhyanastays.com

# Resend (https://resend.com) — get API key from dashboard
RESEND_API_KEY=

# SendGrid (https://sendgrid.com) — get API key from Settings → API Keys
SENDGRID_API_KEY=

# SMTP (any provider: Gmail, Mailgun, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── SMS ───────────────────────────────────────────────────────────────────────
# Provider options: stub | msg91 | twilio
# Use 'stub' for local development (logs SMS to console, no real sending)
SMS_PROVIDER=stub

# MSG91 (https://msg91.com) — India SMS provider
MSG91_AUTH_KEY=
MSG91_SENDER_ID=DHYANA
MSG91_BOOKING_TEMPLATE_ID=

# Twilio (https://twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Storage ───────────────────────────────────────────────────────────────────
# Provider options: stub | s3 | r2
# Use 'stub' for local development (returns placeholder URLs)
STORAGE_PROVIDER=stub

# AWS S3 or S3-compatible (Cloudflare R2, MinIO, etc.)
# For Cloudflare R2: S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT=
S3_BUCKET=dhyana-stays-media
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# CDN_URL: public base URL for media (e.g. https://cdn.dhyanastays.in)
CDN_URL=

# ── Auth0 (optional — dual-mode auth) ────────────────────────────────────────
# When AUTH0_DOMAIN is set: API verifies JWTs via JWKS (RS256) from Auth0.
# When AUTH0_DOMAIN is empty: API uses static HS256 secret (JWT_ACCESS_SECRET).
#
# Setup instructions: see docs/auth0-setup.md
#
# AUTH0_DOMAIN: your tenant domain WITHOUT https:// and WITHOUT trailing slash
#   Example: dev-abc123.us.auth0.com
AUTH0_DOMAIN=

# AUTH0_AUDIENCE: the API Identifier you set in Auth0 → Applications → APIs
#   Example: https://api.dhyanastays.in
AUTH0_AUDIENCE=

# ── Meilisearch ───────────────────────────────────────────────────────────────
# For local Docker: http://localhost:7700
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=meili_dev_key

# ── Stay Pass (themed tickets + QR check-in) ─────────────────────────────────
# Signs check-in QR tokens. Dev: empty = falls back to PRICE_SNAPSHOT_SECRET.
# Production REQUIRES a dedicated 32+ char secret.
QR_SIGNING_SECRET=

# ── Error tracking (Sentry) — optional ───────────────────────────────────────
# Leave SENTRY_DSN empty to disable (the SDK stays completely inert). To enable:
# create a free project at https://sentry.io → copy the DSN here.
SENTRY_DSN=
# 0 = no performance tracing (error capture still works). 0.0–1.0 to sample traces.
SENTRY_TRACES_SAMPLE_RATE=0
# Optional: tag events with a release/version (e.g. a git SHA).
SENTRY_RELEASE=
