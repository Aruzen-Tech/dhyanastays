# ─────────────────────────────────────────────────────────────────────────────
# Dhyana Stays — Frontend Production Environment
# Copy to .env.production.local and fill in your values.
# See docs/cloudflare-deployment.md for setup instructions.
# ─────────────────────────────────────────────────────────────────────────────

# API URL — your deployed NestJS API
NEXT_PUBLIC_API_URL=https://api.dhyanastays.in

# Auth0 (leave ALL blank to use built-in custom JWT auth)
NEXT_PUBLIC_AUTH0_DOMAIN=
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_AUDIENCE=
NEXT_PUBLIC_AUTH0_REDIRECT_URI=https://dhyanastays.in/auth/callback
