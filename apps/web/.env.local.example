# ─────────────────────────────────────────────────────────────────────────────
# Dhyana Stays — Frontend Environment Template (apps/web/.env.local.example)
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── API URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Auth0 (optional) ─────────────────────────────────────────────────────────
# Leave empty to use built-in custom JWT auth (email + password).
# Fill in when you have an Auth0 tenant. See docs/auth0-setup.md.
NEXT_PUBLIC_AUTH0_DOMAIN=
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_AUDIENCE=
NEXT_PUBLIC_AUTH0_REDIRECT_URI=http://localhost:3000/auth/callback
